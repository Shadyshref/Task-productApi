generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  USER
}



model Product {
  id            Int      @id @default(autoincrement())
  sku           String   @unique
  name          String
  description   String?  
  category      String
  type          ProductType
  price         Decimal
  discountPrice Decimal?
  quantity      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum ProductType {
  public
  private
}
